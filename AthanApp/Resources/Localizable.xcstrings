    "Alarm mode plays the full athan sound and bypasses Silent Mode. Requires Alarm permission." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وضع التنبيه يشغل صوت الأذان الكامل ويتجاوز الوضع الصامت. يتطلب إذن التنبيه."
